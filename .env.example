# Environment Variables Example
# Copy this file to .env and fill in the values

# Base URL for the API (e.g., MicroCMS)
VITE_API_BASE_URL=your_api_base_url_here

# API Key for MicroCMS (if needed)
VITE_API_KEY=your_api_key_here

# Site URL (used for sitemap and canonical URLs)
VITE_SITE_URL=https://lineside0418.github.io/AviUtl2_Plugins/

# Google Analytics Tracking ID (optional)
VITE_GA_TRACKING_ID=your_ga_tracking_id_here

# Google Search Console Verification (optional)
VITE_GOOGLE_SITE_VERIFICATION=your_verification_code_here
